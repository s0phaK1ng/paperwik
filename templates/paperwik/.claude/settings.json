{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdates": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.90",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(**)",
      "Glob",
      "Grep",
      "Write(**)",
      "Edit(**)",
      "Agent(*)",
      "WebFetch",
      "WebSearch",
      "Bash(*)"
    ],
    "deny": [
      "Write(C:/**)",
      "Edit(C:/**)",
      "Write(.obsidian/**)",
      "Edit(.obsidian/**)",
      "Write(.git/**)",
      "Edit(.git/**)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Write(knowledge.db)",
      "Edit(knowledge.db)",
      "Write(knowledge.db-wal)",
      "Write(knowledge.db-shm)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(Remove-Item -Recurse*)",
      "Bash(Remove-Item * -Recurse*)",
      "Bash(format *)",
      "Bash(diskpart *)",
      "Bash(shutdown*)",
      "Bash(taskkill /F*)",
      "Bash(del /f /s /q*)",
      "Bash(rmdir /S /Q*)"
    ]
  }
}
