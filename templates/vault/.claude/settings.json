{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoUpdates": false,
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.90",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1"
  },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read(**)",
      "Glob",
      "Grep",
      "Write(Knowledge/**)",
      "Edit(Knowledge/**)",
      "Write(.claude/skills/state/**)",
      "Edit(.claude/skills/state/**)",
      "Write(_Inbox/**)",
      "Edit(_Inbox/**)",
      "Write(_Archive/**)",
      "Edit(_Archive/**)",
      "Agent(*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:huggingface.co)",
      "WebFetch(domain:anthropic.com)",
      "Bash(uv run *)",
      "Bash(git *)",
      "Bash(python -m spacy download *)"
    ],
    "deny": [
      "Write(C:/**)",
      "Edit(C:/**)",
      "Write(.obsidian/**)",
      "Edit(.obsidian/**)",
      "Write(.git/**)",
      "Edit(.git/**)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(knowledge.db)",
      "Edit(knowledge.db)",
      "Write(knowledge.db-wal)",
      "Write(knowledge.db-shm)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(rm -rf*)",
      "Bash(Remove-Item -Recurse*)"
    ]
  }
}
