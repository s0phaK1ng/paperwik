{
  "$comment": "Plugin-level hook registration for Paperwik. Claude Code auto-loads this when the plugin is active. Every hook must (a) exit <1s except SessionStart startup which includes Python bootstrap (60s budget), (b) emit only JSON or silent stdout, (c) use defensive PowerShell patterns. Top-level 'hooks' key and per-hook 'timeout' (in seconds, not ms) match Claude Code's schema as demonstrated by anthropics/claude-plugins-public. ${CLAUDE_PLUGIN_ROOT} is substituted by Claude Code at hook invocation time. Forward slashes in paths — PowerShell accepts them on Windows and they avoid backslash-escape issues when the hook runner interprets the command string through a shell.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/PreToolUse-Governor.ps1\"",
            "timeout": 1
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/scaffold-vault-on-session-start.ps1\"",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Rehydrate-Memory.ps1\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Rehydrate-Memory.ps1\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Restore-State.ps1\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Rehydrate-Memory.ps1\"",
            "timeout": 2
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Auto-Commit.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Save-State.ps1\"",
            "timeout": 2
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Rotate-Memory.ps1\"",
            "timeout": 1
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/Chat-Archive.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
